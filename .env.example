# Required — Bearer token for API authentication
UPVECTOR_TOKEN=your-secret-token-here

# Optional — defaults shown
# UPVECTOR_REDIS_URL=redis://localhost:6379
# UPVECTOR_PORT=8080
# UPVECTOR_METRIC=COSINE
# UPVECTOR_DIMENSION=         # Auto-detected from first upsert if omitted
# UPVECTOR_LOG_LEVEL=info
# UPVECTOR_LOG_FORMAT=json    # json or text
# UPVECTOR_SHUTDOWN_TIMEOUT=30000   # Max ms to wait for request drain on shutdown
# UPVECTOR_REQUEST_TIMEOUT=30000    # Per-request timeout in ms (0 = disabled)
# UPVECTOR_METRICS=false      # Enable Prometheus /metrics endpoint
