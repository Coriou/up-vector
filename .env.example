# Required — Bearer token for API authentication.
# Token characters must match [A-Za-z0-9._~+/-]+=* (RFC 6750 bearer token charset).
UPVECTOR_TOKEN=your-secret-token-here

# Optional — defaults shown
# UPVECTOR_REDIS_URL=redis://localhost:6379
# UPVECTOR_PORT=8080
# UPVECTOR_HOST=0.0.0.0
# UPVECTOR_METRIC=COSINE
# UPVECTOR_DIMENSION=         # Auto-detected from first upsert if omitted
# UPVECTOR_LOG_LEVEL=info
# UPVECTOR_LOG_FORMAT=json    # json or text
# UPVECTOR_SHUTDOWN_TIMEOUT=30000   # Max ms to wait for request drain on shutdown
# UPVECTOR_REQUEST_TIMEOUT=30000    # Per-request timeout in ms (0 = disabled)
# UPVECTOR_MAX_BODY_SIZE=33554432   # Max request body size in bytes (default 32 MiB)
# UPVECTOR_METRICS=false      # Enable Prometheus /metrics endpoint

# Optional — server-side embeddings for /upsert-data and /query-data.
# Default is disabled; client-generated embeddings continue to work without this.
# UPVECTOR_EMBEDDING_PROVIDER=disabled       # disabled, openai, or fake
# UPVECTOR_EMBEDDING_MODEL=text-embedding-3-small
# UPVECTOR_EMBEDDING_DIMENSION=1536          # Optional expected dimension
# UPVECTOR_EMBEDDING_BASE_URL=https://api.openai.com/v1
# UPVECTOR_EMBEDDING_API_KEY=sk-...
# UPVECTOR_EMBEDDING_TIMEOUT_MS=10000        # Per embedding request timeout (0 = disabled)
# UPVECTOR_EMBEDDING_RETRIES=2               # Retries for timeout, 429, and 5xx

# Test/dev only: deterministic fake embeddings, not semantic.
# UPVECTOR_EMBEDDING_PROVIDER=fake
# UPVECTOR_EMBEDDING_MODEL=fake-embedding
# UPVECTOR_EMBEDDING_DIMENSION=8
